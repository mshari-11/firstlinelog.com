{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🚀 Launch Dev Server & Debug",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src",
      "preLaunchTask": "🚀 Dev Server (npm run dev)",
      "sourceMapPathOverrides": {
        "/@/*": "${workspaceFolder}/src/*"
      }
    },
    {
      "name": "🔗 Attach to Chrome",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/src"
    }
  ]
}
