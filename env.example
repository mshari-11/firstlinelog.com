# =====================================================
# FLL Environment Variables
# فيرست لاين لوجستيكس — متغيرات البيئة
# =====================================================

# --- AWS Core ---
AWS_REGION=me-south-1
ALLOWED_ORIGIN=https://fll.sa

# --- Cognito ---
USER_POOL_ID=me-south-1_CHANGEME
COGNITO_CLIENT_ID=CHANGEME
COGNITO_CLIENT_SECRET=

# --- Aurora PostgreSQL (Finance Engine) ---
AURORA_HOST=
AURORA_PORT=5432
AURORA_DATABASE=fll_finance
AURORA_USERNAME=
AURORA_PASSWORD=
AURORA_SSL=true

# --- S3 Buckets ---
KYC_BUCKET=fll-kyc-documents-CHANGEME
OPS_RAW_BUCKET=fll-ops-raw

# --- AI / Bedrock ---
BEDROCK_REGION=me-south-1
FINANCE_MODEL_ID=anthropic.claude-sonnet-4-6-20250514
CHAT_MODEL_ID=anthropic.claude-sonnet-4-6-20250514
MAX_TOKENS=1024

# --- Nected Rules Engine ---
NECTED_API_URL=
NECTED_API_KEY=
# Note: Nected deployment requires subdomain + ACM certificate via CloudFormation

# --- n8n Integration Hub ---
N8N_WEBHOOK_BASE_URL=
N8N_API_KEY=
# Note: n8n runs inside VPC, supports SSO/RBAC in Enterprise tier

# --- Veri5now eSign ---
VERI5NOW_API_URL=
VERI5NOW_API_KEY=
# Note: eSign/onboarding only. Saudi eKYC NOT activated - awaiting vendor confirmation

# --- AI Financial Report Analyst ---
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS=
# Note: Read-only Bedrock AgentCore for financial analysis

# --- Turiya AI (Pilot — disabled by default) ---
TURIYA_API_URL=
TURIYA_API_KEY=
# Note: Multi-agent orchestration pilot. Read-only. Not in core finance path.

# --- Feature Flags (DynamoDB system-settings) ---
# These are stored in DynamoDB, not env vars. Listed here for documentation.
# FEATURE_FINANCE_ENGINE=false
# FEATURE_AURORA_ENABLED=false
# FEATURE_WALLET_LEDGER=false
# FEATURE_RECONCILIATION=false
# FEATURE_FRAUD_DETECTION=false
# FEATURE_NECTED_ENABLED=false
# FEATURE_N8N_ENABLED=false
# FEATURE_VERI5NOW_ENABLED=false
# FEATURE_AI_FINANCE_INSIGHTS=false
# FEATURE_TURIYA_ENABLED=false

# --- Email (SES) ---
ADMIN_EMAILS=admin@example.com
