{
  "buildCommand": "",
  "framework": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/login", "destination": "/index.html" },
    { "source": "/unified-login", "destination": "/index.html" },
    { "source": "/about", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/services", "destination": "/index.html" },
    { "source": "/news", "destination": "/index.html" },
    { "source": "/investors", "destination": "/index.html" },
    { "source": "/terms", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/compliance", "destination": "/index.html" },
    { "source": "/operational-model", "destination": "/index.html" },
    { "source": "/employee-services", "destination": "/index.html" },
    { "source": "/courier-dashboard", "destination": "/index.html" },
    { "source": "/staff-dashboard", "destination": "/index.html" },
    { "source": "/github-management", "destination": "/index.html" }
  ],
  "headers": [
    { "source": "/(.*).html", "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }] },
    { "source": "/fll-*.js", "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }] }
  ]
}
