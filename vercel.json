{
    "installCommand": "npm install",
    "buildCommand": "npm run build",
    "framework": null,
    "outputDirectory": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
          { "source": "/admin-panel/(.*)", "destination": "/dist/spa.html" },
          { "source": "/admin-panel", "destination": "/dist/spa.html" },
          { "source": "/admin/login", "destination": "/dist/spa.html" },
          { "source": "/login", "destination": "/dist/spa.html" },
          { "source": "/unified-login", "destination": "/dist/spa.html" },
          { "source": "/courier/register", "destination": "/dist/spa.html" },
          { "source": "/courier/(.*)", "destination": "/dist/spa.html" },
          { "source": "/application-status", "destination": "/dist/spa.html" },
          { "source": "/services/(.*)", "destination": "/dist/spa.html" },
          { "source": "/register", "destination": "/dist/spa.html" },
          { "source": "/admin/(.*)", "destination": "/dist/spa.html" },
          { "source": "/driver/(.*)", "destination": "/dist/spa.html" },
          { "source": "/about", "destination": "/" },
          { "source": "/contact", "destination": "/" },
          { "source": "/services", "destination": "/" },
          { "source": "/news", "destination": "/" },
          { "source": "/investors", "destination": "/" },
          { "source": "/terms", "destination": "/" },
          { "source": "/privacy", "destination": "/" },
          { "source": "/compliance", "destination": "/" },
          { "source": "/operational-model", "destination": "/" },
          { "source": "/employee-services", "destination": "/" },
          { "source": "/github-management", "destination": "/" }
    ],
    "headers": [
          { "source": "/(.*).html", "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }] },
          { "source": "/", "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }] }
    ]
}
