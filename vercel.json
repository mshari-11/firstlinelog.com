{
  "buildCommand": "",
  "framework": null,
  "outputDirectory": ".",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/admin-dashboard", "dest": "/admin-dashboard.html" },
    { "src": "/staff-dashboard", "dest": "/staff-dashboard.html" },
    { "src": "/courier-dashboard", "dest": "/courier-dashboard.html" },
    { "src": "/staff-finance", "dest": "/staff-finance.html" },
    { "src": "/staff-hr", "dest": "/staff-hr.html" },
    { "src": "/staff-ops", "dest": "/staff-ops.html" },
    { "src": "/staff-fleet", "dest": "/staff-fleet.html" },
    { "src": "/unauthorized", "dest": "/unauthorized.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    { "source": "/(.*).html", "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }] },
    { "source": "/fll-*.js", "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }] }
  ]
}
